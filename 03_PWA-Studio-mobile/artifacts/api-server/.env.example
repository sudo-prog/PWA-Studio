# PWA Studio — Mobile API server
# Copy to .env (gitignored) and fill in real values.

DATABASE_URL=postgresql://USER@HOST:5432/pwa_studio_mobile
PORT=3000

# (Optional) GitHub integration — required for director/github routes
GITHUB_TOKEN=

# (Optional) Clerk auth (mobile app uses @clerk/expo)
CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
