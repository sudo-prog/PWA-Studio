# PWA Studio — Pro API server
# Copy to .env (gitignored) and fill in real values.

# PostgreSQL connection string used by Drizzle ORM + drizzle-kit
DATABASE_URL=postgresql://USER@HOST:5432/pwa_studio_pro

# Port the Express API listens on
PORT=3000

# (Optional) OpenAI key — only required for the AI chat feature
OPENAI_API_KEY=

# (Optional) Base URL override for the OpenAI-compatible endpoint (SSRF-guarded: http/https only)
OPENAI_BASE_URL=https://api.openai.com/v1
