{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd 02_PWA-Studio-Pro && pnpm install && pnpm --filter @workspace/studio run build",
  "installCommand": "cd 02_PWA-Studio-Pro && pnpm install",
  "outputDirectory": "02_PWA-Studio-Pro/artifacts/studio/dist/public",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/((?!api/|assets/|icons/|favicon.ico|manifest.webmanifest|sw.js|workbox-.*\\.js|registerSW.js).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
    }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
